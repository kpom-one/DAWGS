{
  "cases": [
    {
      "name": "shortest path picks direct edge over longer route",
      "cypher": "MATCH p = allShortestPaths((s)-[*1..]->(e)) WHERE s.name = 'a' AND e.name = 'd' RETURN p",
      "fixture": {
        "nodes": [
          {
            "id": "a",
            "kinds": [
              "NodeKind1"
            ],
            "properties": {
              "name": "a"
            }
          },
          {
            "id": "b",
            "kinds": [
              "NodeKind1"
            ],
            "properties": {
              "name": "b"
            }
          },
          {
            "id": "c",
            "kinds": [
              "NodeKind1"
            ],
            "properties": {
              "name": "c"
            }
          },
          {
            "id": "d",
            "kinds": [
              "NodeKind1"
            ],
            "properties": {
              "name": "d"
            }
          }
        ],
        "edges": [
          {
            "start_id": "a",
            "end_id": "b",
            "kind": "EdgeKind1"
          },
          {
            "start_id": "b",
            "end_id": "c",
            "kind": "EdgeKind1"
          },
          {
            "start_id": "c",
            "end_id": "d",
            "kind": "EdgeKind1"
          },
          {
            "start_id": "a",
            "end_id": "d",
            "kind": "EdgeKind1"
          }
        ]
      },
      "assert": {
        "row_count": 1
      },
      "skip_drivers": [
        "sonic"
      ]
    },
    {
      "name": "multiple shortest paths of equal length",
